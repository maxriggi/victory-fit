---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import ContentSection from '../../components/ContentSection.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Body Sculpt — Victory Fit" description="Cours de renforcement musculaire Body Sculpt chez Victory Fit à Metz : tonifiez, renforcez et sculptez votre corps.">

  <HeroSection
    title="Body Sculpt"
    highlightWord="Sculpt"
    subtitle="Renforcement musculaire complet pour tonifier, renforcer et sculpter votre corps.<br><strong>Accessible, progressif, efficace.</strong>"
    backgroundImage="https://images.unsplash.com/photo-1583454110551-21f2fa2afe61?w=1920&q=80"
    ctas={[
      { label: 'Voir le planning', href: `${base}planning`, variant: 'primary' },
      { label: 'Essai gratuit', href: `${base}contact`, variant: 'secondary' },
    ]}
  />

  <ContentSection
    label="Le concept"
    title="Un entraînement complet"
    mediaSrc="https://images.unsplash.com/photo-1583454110551-21f2fa2afe61?w=800&q=80"
    mediaAlt="Body Sculpt"
    mediaPosition="right"
  >
    <p>Le Body Sculpt est un cours de renforcement musculaire qui cible l'ensemble du corps a travers des exercices variés avec halteres, kettlebells et poids du corps.</p>
    <p>Chaque séance travaille le haut du corps, le bas du corps et le gainage pour un développement équilibre.</p>
    <ul>
      <li>Tonifier et dessiner la silhouette</li>
      <li>Renforcer les muscles en profondeur</li>
      <li>Améliorer la posture</li>
      <li>Progresser à son rythme avec des charges adaptées</li>
    </ul>
    <p><strong>Accessible à tous les niveaux, avec des progressions adaptées.</strong></p>
  </ContentSection>

  <ContentSection
    title="Prêt a vous sculpter ?"
    fullWidth={true}
    variant="gradient"
    ctas={[
      { label: 'Voir le planning', href: `${base}planning`, variant: 'primary' },
      { label: 'Essai gratuit', href: `${base}contact`, variant: 'secondary' },
    ]}
  >
    <p><strong>La première victoire commence par une décision.</strong></p>
  </ContentSection>

</BaseLayout>
