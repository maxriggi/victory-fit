---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import ContentSection from '../../components/ContentSection.astro';
import RelatedCourses from '../../components/RelatedCourses.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Cardio Training — Victory Fit" description="Cours de cardio HIIT chez Victory Fit à Metz : des séances dynamiques pour brûler des calories, améliorer son endurance et se remettre en forme." breadcrumbs={[{ label: 'Accueil', href: base }, { label: 'Les Cours', href: base + 'cours' }, { label: 'Cardio Training' }]}>

  <HeroSection
    title="Cardio Training"
    highlightWord="Cardio"
    subtitle="Des séances HIIT dynamiques pour brûler, transpirer et progresser.<br><strong>Tous les niveaux, toute l'énergie.</strong>"
    backgroundImage="https://images.unsplash.com/photo-1601422407692-ec4eeec1d9b3?w=1920&q=80"
    ctas={[
      { label: 'Voir le planning', href: `${base}planning`, variant: 'primary' },
      { label: 'Essai gratuit', href: `${base}contact`, variant: 'secondary' },
    ]}
  />

  <ContentSection
    label="Le concept"
    title="HIIT : High Intensity Interval Training"
    mediaSrc="https://images.unsplash.com/photo-1601422407692-ec4eeec1d9b3?w=800&q=80"
    mediaAlt="Cardio Training HIIT"
    mediaPosition="right"
  >
    <p>Le cardio training chez Victory Fit est basé sur le HIIT : des phases d'effort intense alternées avec des phases de récupération active.</p>
    <p>Ce format est reconnu comme l'un des plus efficaces pour améliorer la condition cardiovasculaire et brûler des calories — y compris après la séance grâce à l'effet afterburn (EPOC).</p>
    <p><strong>Des séances rythmées, accessibles et adaptées à tous les niveaux.</strong></p>
  </ContentSection>

  <ContentSection
    label="Les bénéfices"
    title="Pourquoi le cardio HIIT ?"
    fullWidth={true}
    variant="dark"
  >
    <ul>
      <li>Brûler des calories efficacement — pendant et après la séance</li>
      <li>Améliorer sa capacité cardiovasculaire et respiratoire</li>
      <li>Gagner en endurance et en énergie au quotidien</li>
      <li>Se remettre en forme rapidement</li>
      <li>Boost du métabolisme sur plusieurs heures</li>
      <li>Séances variées — jamais la même routine</li>
    </ul>
  </ContentSection>

  <RelatedCourses currentSlug="cardio-training" />

  <ContentSection
    title="Prêt à repousser vos limites cardio ?"
    fullWidth={true}
    variant="gradient"
    ctas={[
      { label: 'Voir le planning', href: `${base}planning`, variant: 'primary' },
      { label: 'Essai gratuit', href: `${base}contact`, variant: 'secondary' },
    ]}
  >
    <p><strong>La première victoire commence par une décision.</strong></p>
  </ContentSection>

</BaseLayout>
