---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import ContentSection from '../components/ContentSection.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Planning — Victory Fit" description="Consultez le planning des cours collectifs Victory Fit à Metz." breadcrumbs={[{ label: 'Accueil', href: base }, { label: 'Planning' }]}>

  <HeroSection
    title="Planning des cours"
    highlightWord="cours"
    subtitle="Plusieurs créneaux chaque jour pour s'entraîner quand vous voulez.<br>Matin, midi ou soir, chacun peut trouver sa séance."
    backgroundImage="https://images.unsplash.com/photo-1596357395217-80de13130e92?w=1920&q=80"
    ctas={[
      { label: 'Réserver un cours d\'essai gratuit', href: `${base}contact`, variant: 'primary' },
      { label: 'Je rejoins la famille Victory Fit', href: `${base}contact`, variant: 'secondary' },
    ]}
  />

  <section class="sportigo-section" data-aos="fade-up">
    <div class="container">
      <h2 class="sportigo-title">Réservez votre cours</h2>
      <div id="sportigo-appointment-container"></div>
    </div>
  </section>

  <script is:inline src="https://standalone.api.sportigo.fr/component-standalone.js"></script>
  <script is:inline>
    initComponent("Appointment", "sportigo-appointment-container", "2b0a9501-fb94-49ab-bca8-d660557b76c1", {
      "readonly": false,
      "forceBookBtn": false,
      "colored": true
    });
  </script>

  <style>
    .sportigo-section {
      padding: var(--section-padding);
    }
    .sportigo-title {
      text-align: center;
      margin-bottom: 2rem;
    }
    #sportigo-appointment-container {
      max-width: 1100px;
      margin: 0 auto;
    }
  </style>

  <ContentSection
    title="Prêt à commencer ?"
    fullWidth={true}
    variant="gradient"
    ctas={[
      { label: 'Réserver un cours d\'essai gratuit', href: `${base}contact`, variant: 'primary' },
      { label: 'Voir les cours', href: `${base}cours`, variant: 'secondary' },
      { label: 'Je rejoins la famille Victory Fit', href: `${base}contact`, variant: 'secondary' },
    ]}
  >
    <p><strong>La première victoire commence par une décision.</strong></p>
  </ContentSection>

</BaseLayout>
