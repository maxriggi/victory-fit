---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import ContentSection from '../../components/ContentSection.astro';
import CourseCard from '../../components/CourseCard.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Les Cours — Victory Fit" description="Découvrez tous les cours Victory Fit : Les Mills, Bungee Fitness, Boxe, Cardio, Body Sculpt, EMS, Step, Yoga et plus." breadcrumbs={[{ label: 'Accueil', href: base }, { label: 'Les Cours' }]}>

  <!-- HERO -->
  <HeroSection
    title="Les cours Victory Fit"
    highlightWord="Victory Fit"
    subtitle="Des entraînements variés, dynamiques et accessibles à tous.<br>Des cours collectifs en présentiel et en illimité, au cœur du centre-ville de Metz.<br><br>Ici, chaque séance est différente. Mais l'objectif reste le même : <strong>se dépasser, progresser et prendre du plaisir.</strong>"
    backgroundImage="https://images.unsplash.com/photo-1534258936925-c58bed479fcb?w=1920&q=80"
    ctas={[
      { label: 'Voir le planning', href: `${base}planning`, variant: 'primary' },
      { label: 'Réserver un cours d\'essai gratuit', href: `${base}contact`, variant: 'secondary' },
      { label: 'Je rejoins la famille Victory Fit', href: `${base}contact`, variant: 'secondary' },
    ]}
  />

  <!-- COURS COLLECTIFS -->
  <ContentSection
    title="Les cours collectifs"
    mediaSrc="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=800&q=80"
    mediaAlt="Cours collectifs Victory Fit"
    mediaPosition="right"
    ctas={[
      { label: 'Voir le planning', href: `${base}planning`, variant: 'primary' },
    ]}
  >
    <p>Chez Victory Fit, les cours collectifs sont au cœur de l'expérience.</p>
    <p>L'énergie du groupe, la musique et le coaching créent une dynamique unique.</p>
    <p>Les séances sont en présentiel et en illimité, pour vous permettre de venir aussi souvent que vous le souhaitez.</p>
    <p>Musique, motivation, énergie collective... tout est fait pour vous donner envie de revenir.</p>
    <p><strong>Que vous soyez débutant ou confirmé, chacun trouve sa place.</strong></p>
  </ContentSection>

  <!-- TOUS LES COURS -->
  <CourseCard
    label="Nos cours"
    title="Trouvez votre entraînement"
    courses={[
      { image: 'https://images.unsplash.com/photo-1534258936925-c58bed479fcb?w=800&q=80', title: 'Les Mills', description: 'Programmes rythmés par la musique, structurés et motivants.', href: `${base}cours/les-mills` },
      { image: 'https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=800&q=80', title: 'Bungee Fitness', description: 'Sautez, volez et réalisez des mouvements dynamiques en apesanteur.', href: `${base}cours/bungee-fitness` },
      { image: 'https://images.unsplash.com/photo-1549719386-74dfcbf7dbed?w=800&q=80', title: 'Boxe Training', description: 'Un entraînement explosif mêlant puissance, technique et cardio.', href: `${base}cours/boxe-training` },
      { image: 'https://images.unsplash.com/photo-1538805060514-97d9cc17730c?w=800&q=80', title: 'Cardio Training', description: 'Séances HIIT pour brûler des calories et améliorer l\'endurance.', href: `${base}cours/cardio-training` },
      { image: 'https://images.unsplash.com/photo-1581009146145-b5ef050c2e1e?w=800&q=80', title: 'Body Sculpt', description: 'Renforcement musculaire complet pour tonifier tout le corps.', href: `${base}cours/body-sculpt` },
      { image: 'https://images.unsplash.com/photo-1576678927484-cc907957088c?w=800&q=80', title: 'EMS', description: 'Électrostimulation en coaching privé pour des résultats intensifs.', href: `${base}cours/ems` },
      { image: 'https://images.unsplash.com/photo-1518611012118-696072aa579a?w=800&q=80', title: 'Step Freestyle', description: 'Cours chorégraphié mêlant cardio, coordination et rythme.', href: `${base}cours/step-freestyle` },
      { image: 'https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=800&q=80', title: 'Sport doux', description: 'Yoga, pilates et stretching pour le bien-être et la récupération.', href: `${base}cours/sport-doux` },
      { image: 'https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=800&q=80', title: 'Coaching personnalisé', description: 'Un accompagnement sur mesure adapté à vos objectifs.', href: `${base}coaching` },
    ]}
  />

  <!-- POUR TOUS LES NIVEAUX -->
  <ContentSection
    title="Pour tous les niveaux"
    fullWidth={true}
  >
    <p>Chez Victory Fit, chacun vient avec son niveau. Débutant. Sportif. Ou simplement avec l'envie de bouger.</p>
    <p>Chaque exercice peut être adapté. Ici, il n'y a pas de jugement. Seulement : de la progression, de la motivation, de l'énergie.</p>
    <p><strong>L'objectif est de devenir meilleur qu'hier.</strong></p>
  </ContentSection>

  <!-- L'EXPÉRIENCE VICTORY FIT -->
  <ContentSection
    title="L'expérience Victory Fit"
    fullWidth={true}
    variant="dark"
  >
    <p>Au-delà des exercices, chaque séance est une expérience.</p>
    <p>Une énergie collective. Une motivation constante. Un dépassement de soi.</p>
    <p>Et toujours cette sensation : <strong>la victoire sur soi-même.</strong></p>
  </ContentSection>

  <!-- FINAL CTA -->
  <ContentSection
    title="Prêt à découvrir les cours Victory Fit ?"
    fullWidth={true}
    variant="gradient"
    ctas={[
      { label: 'Réserver un cours d\'essai gratuit', href: `${base}contact`, variant: 'primary' },
      { label: 'Voir le planning', href: `${base}planning`, variant: 'secondary' },
      { label: 'Je rejoins la famille Victory Fit', href: `${base}contact`, variant: 'secondary' },
    ]}
  >
    <p><strong>La première victoire commence par une décision.</strong></p>
  </ContentSection>

</BaseLayout>
