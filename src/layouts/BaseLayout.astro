---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const base = import.meta.env.BASE_URL;

const {
  title,
  description = 'Victory Fit — La salle de sport du centre-ville de Metz dédiée aux cours collectifs en présentiel. Sportivement Metz.',
  ogImage = `${base}assets/logo-version-a-full.png`,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://victoryfit.fr');
const ogImageURL = new URL(ogImage, Astro.site || 'https://victoryfit.fr');
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>

  <!-- Canonical -->
  <link rel="canonical" href={canonicalURL.href}>

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonicalURL.href}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImageURL.href}>
  <meta property="og:locale" content="fr_FR">
  <meta property="og:site_name" content="Victory Fit">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImageURL.href}>

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="32x32" href={`${base}assets/favicon-32.png`}>
  <link rel="icon" type="image/png" href={`${base}assets/logo-version-b-icon.png`}>

  <!-- Fonts (placeholders — replace with Domus Titling & New Zen) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
  <noscript>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </noscript>

  <!-- AOS (async CSS) -->
  <link rel="preload" as="style" href="https://unpkg.com/aos@2.3.4/dist/aos.css">
  <link rel="stylesheet" href="https://unpkg.com/aos@2.3.4/dist/aos.css" media="print" onload="this.media='all'">
  <noscript>
    <link rel="stylesheet" href="https://unpkg.com/aos@2.3.4/dist/aos.css">
  </noscript>
</head>
<body>
  <Navbar />
  <main>
    <slot />
  </main>
  <Footer />

  <script is:inline src="https://unpkg.com/aos@2.3.4/dist/aos.js" defer></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      if (typeof AOS !== 'undefined') {
        AOS.init({
          duration: 800,
          easing: 'ease-out',
          once: true,
          offset: 80,
        });
      }
    });
  </script>
</body>
</html>
