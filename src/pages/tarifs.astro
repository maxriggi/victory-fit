---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import ContentSection from '../components/ContentSection.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Tarifs — Victory Fit" description="Découvrez les tarifs Victory Fit : cours collectifs en illimité au cœur de Metz." breadcrumbs={[{ label: 'Accueil', href: base }, { label: 'Tarifs' }]}>

  <HeroSection
    title="Nos tarifs"
    highlightWord="tarifs"
    subtitle="Des cours collectifs en présentiel et en illimité.<br>Plus vous venez, plus vous progressez."
    backgroundImage="https://images.unsplash.com/photo-1593079831268-3381b0db4a77?w=1920&q=80"
    ctas={[
      { label: 'Essai gratuit', href: `${base}contact`, variant: 'primary' },
    ]}
  />

  <ContentSection
    title="Tarifs a venir"
    fullWidth={true}
  >
    <p>La grille tarifaire détaillée sera bientôt disponible.</p>
    <p><strong>Contactez-nous pour découvrir nos offres et bénéficier d'un cours d'essai gratuit.</strong></p>
  </ContentSection>

  <ContentSection
    title="Prêt a nous rejoindre ?"
    fullWidth={true}
    variant="gradient"
    ctas={[
      { label: 'Nous contacter', href: `${base}contact`, variant: 'primary' },
      { label: 'Voir les cours', href: `${base}cours`, variant: 'secondary' },
    ]}
  >
    <p><strong>La première victoire commence par une décision.</strong></p>
  </ContentSection>

</BaseLayout>
