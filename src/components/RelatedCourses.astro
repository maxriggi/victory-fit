---
interface Props {
  currentSlug: string;
}

const base = import.meta.env.BASE_URL;
const { currentSlug } = Astro.props;

const allCourses = [
  { slug: 'les-mills', label: 'Les Mills', icon: '💪' },
  { slug: 'bungee-fitness', label: 'Bungee Fitness', icon: '🪂' },
  { slug: 'boxe-training', label: 'Boxe Training', icon: '🥊' },
  { slug: 'cardio-training', label: 'Cardio Training', icon: '❤️‍🔥' },
  { slug: 'body-sculpt', label: 'Body Sculpt', icon: '🏋️' },
  { slug: 'ems', label: 'EMS', icon: '⚡' },
  { slug: 'step-freestyle', label: 'Step Freestyle', icon: '🎵' },
  { slug: 'sport-doux', label: 'Sport Doux', icon: '🧘' },
];

const related = allCourses.filter(c => c.slug !== currentSlug);
---

<section class="related-courses" data-aos="fade-up">
  <div class="related-courses__inner container">
    <h2>Découvrez nos autres cours</h2>
    <div class="related-courses__grid">
      {related.map(course => (
        <a href={`${base}cours/${course.slug}`} class="related-courses__card">
          <span class="related-courses__icon">{course.icon}</span>
          <span class="related-courses__label">{course.label}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .related-courses {
    padding: var(--section-padding);
    background: var(--bg-light);
    border-top: 1px solid var(--white-10);
  }

  .related-courses__inner {
    text-align: center;
  }

  .related-courses__inner h2 {
    margin-bottom: 2rem;
  }

  .related-courses__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1rem;
  }

  .related-courses__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.25rem 1rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--white-10);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.3s ease, transform 0.2s ease;
  }

  .related-courses__card:hover {
    border-color: var(--orange);
    transform: translateY(-2px);
  }

  .related-courses__icon {
    font-size: 1.5rem;
  }

  .related-courses__label {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--white-70);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .related-courses__card:hover .related-courses__label {
    color: var(--white);
  }

  @media (max-width: 600px) {
    .related-courses__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
