---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import ContentSection from '../components/ContentSection.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Planning — Victory Fit" description="Consultez le planning des cours collectifs Victory Fit à Metz." breadcrumbs={[{ label: 'Accueil', href: base }, { label: 'Planning' }]}>

  <HeroSection
    title="Planning des cours"
    highlightWord="cours"
    subtitle="Plusieurs créneaux chaque jour pour s'entraîner quand vous voulez.<br>Matin, midi ou soir, chacun peut trouver sa séance."
    backgroundImage="https://images.unsplash.com/photo-1596357395217-80de13130e92?w=1920&q=80"
    ctas={[
      { label: 'Essai gratuit', href: `${base}contact`, variant: 'primary' },
    ]}
  />

  <ContentSection
    title="Planning a venir"
    fullWidth={true}
  >
    <p>Le planning détaillé des cours sera bientôt disponible.</p>
    <p><strong>Contactez-nous pour connaître les horaires et réserver votre premier cours d'essai gratuit.</strong></p>
  </ContentSection>

  <ContentSection
    title="Prêt a commencer ?"
    fullWidth={true}
    variant="gradient"
    ctas={[
      { label: 'Nous contacter', href: `${base}contact`, variant: 'primary' },
      { label: 'Voir les cours', href: `${base}cours`, variant: 'secondary' },
    ]}
  >
    <p><strong>La première victoire commence par une décision.</strong></p>
  </ContentSection>

</BaseLayout>
