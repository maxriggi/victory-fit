---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import ContentSection from '../../components/ContentSection.astro';
import RelatedCourses from '../../components/RelatedCourses.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Step Freestyle — Victory Fit" description="Cours de Step Freestyle chez Victory Fit à Metz : un cours dynamique et rythmé basé sur des enchaînements chorégraphiés." breadcrumbs={[{ label: 'Accueil', href: base }, { label: 'Les Cours', href: base + 'cours' }, { label: 'Step Freestyle' }]}>

  <HeroSection
    title="Step Freestyle"
    highlightWord="Step"
    subtitle="Un cours dynamique et rythmé basé sur des enchaînements chorégraphiés autour du step.<br><strong>Cardio, coordination et plaisir.</strong>"
    backgroundImage="https://images.unsplash.com/photo-1594737625785-a6cbdabd333c?w=1920&q=80"
    ctas={[
      { label: 'Voir le planning', href: `${base}planning`, variant: 'primary' },
      { label: 'Essai gratuit', href: `${base}contact`, variant: 'secondary' },
    ]}
  />

  <ContentSection
    label="Le concept"
    title="Bougez au rythme de la musique"
    mediaSrc="https://images.unsplash.com/photo-1594737625785-a6cbdabd333c?w=800&q=80"
    mediaAlt="Step Freestyle"
    mediaPosition="right"
  >
    <p>Le Step Freestyle utilise une plateforme surélevée (le step) comme base pour des enchaînements chorégraphiés sur une musique entraînante.</p>
    <p>C'est une activité complète qui combine :</p>
    <ul>
      <li>Cardio — le cœur travaille en continu</li>
      <li>Coordination — enchainer les pas et les mouvements</li>
      <li>Rythme — suivre la musique et le tempo</li>
      <li>Mémoire — retenir et anticiper les séquences</li>
    </ul>
    <p>Accessible à tous avec des niveaux progressifs. <strong>Pas besoin d'être danseur — l'important est de bouger et de s'amuser.</strong></p>
  </ContentSection>

  <RelatedCourses currentSlug="step-freestyle" />

  <ContentSection
    title="Prêt à monter sur le step ?"
    fullWidth={true}
    variant="gradient"
    ctas={[
      { label: 'Voir le planning', href: `${base}planning`, variant: 'primary' },
      { label: 'Essai gratuit', href: `${base}contact`, variant: 'secondary' },
    ]}
  >
    <p><strong>La première victoire commence par une décision.</strong></p>
  </ContentSection>

</BaseLayout>
