---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import ContentSection from '../components/ContentSection.astro';
import ProcessTimeline from '../components/ProcessTimeline.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Coaching Personnalisé — Victory Fit" description="Un accompagnement sur mesure pour atteindre vos objectifs plus rapidement. Coaching en présentiel chez Victory Fit à Metz." breadcrumbs={[{ label: 'Accueil', href: base }, { label: 'Coaching Personnalisé' }]}>

  <!-- HERO -->
  <HeroSection
    title="Coaching personnalisé"
    highlightWord="personnalisé"
    subtitle="Un accompagnement sur mesure pour atteindre vos objectifs plus rapidement.<br>Coaching en présentiel, directement dans la salle Victory Fit.<br><br>Ici, vous n'êtes pas un simple adhérent. Vous êtes suivi, encadré et guidé à chaque étape."
    backgroundImage="https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=1920&q=80"
    ctas={[
      { label: 'Nous contacter', href: `${base}contact`, variant: 'primary' },
      { label: 'Demander un bilan gratuit', href: `${base}contact`, variant: 'secondary' },
      { label: 'Je rejoins la famille Victory Fit', href: `${base}contact`, variant: 'secondary' },
    ]}
  />

  <!-- POUR QUI -->
  <ContentSection
    label="Pour qui ?"
    title="Un coaching adapté à vous"
    mediaSrc="https://images.unsplash.com/photo-1550345332-09e3ac987658?w=800&q=80"
    mediaAlt="Séance individuelle"
    mediaPosition="right"
  >
    <p>Le coaching personnalisé s'adresse à toutes les personnes qui veulent des résultats concrets.</p>
    <p>Que vous soyez :</p>
    <ul>
      <li>Débutant</li>
      <li>En reprise sportive</li>
      <li>Sportif confirmé</li>
      <li>Ou avec un objectif précis</li>
    </ul>
    <p><strong>Ce suivi est fait pour vous.</strong></p>
  </ContentSection>

  <!-- OBJECTIFS -->
  <ContentSection
    label="Vos objectifs"
    title="Des objectifs clairs"
    mediaSrc="https://images.unsplash.com/photo-1548690312-e3b507d8c110?w=800&q=80"
    mediaAlt="Transformation et effort"
    mediaPosition="left"
    variant="dark"
  >
    <p>Chaque programme est construit selon vos besoins :</p>
    <ul>
      <li>Remise en forme</li>
      <li>Perte de poids ou prise de masse</li>
      <li>Bien-être physique et mental</li>
      <li>Préparation physique</li>
      <li>Initiation à la boxe</li>
      <li>Ou tout autre objectif spécifique</li>
    </ul>
    <p><strong>Chaque accompagnement est entièrement personnalisé pour s'adapter à votre profil et à vos attentes.</strong></p>
  </ContentSection>

  <!-- RESULTATS -->
  <ContentSection
    label="Résultats"
    title="Des résultats visibles"
    mediaSrc="https://images.unsplash.com/photo-1593079831268-3381b0db4a77?w=800&q=80"
    mediaAlt="Résultats coaching"
    mediaPosition="right"
  >
    <p>Avec un suivi personnalisé, les résultats sont réels et mesurables.</p>
    <p>Transformation physique, amélioration des performances, bien-être...</p>
    <p><strong>Les progrès se voient et se ressentent.</strong></p>
  </ContentSection>

  <!-- BENEFICES -->
  <FeatureGrid
    label="Les bénéfices"
    title="Un accompagnement qui fait la différence"
    variant="dark"
    features={[
      { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>', title: 'Personnalisé', description: 'Programme 100% adapté à votre niveau et à vos objectifs.' },
      { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>', title: 'Progression rapide', description: 'Suivi individuel pour des résultats concrets et mesurables.' },
      { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h1c1.5 0 2-1.5 3-1.5s1.5 1.5 3 1.5 2-1.5 3-1.5 1.5 1.5 3 1.5 2-1.5 3-1.5h1"/><path d="M3 8h1c1.5 0 2 1.5 3 1.5S8.5 8 10 8s2 1.5 3 1.5S14.5 8 16 8s2 1.5 3 1.5H21"/><rect x="5" y="14" width="14" height="4" rx="1"/></svg>', title: 'Motivation constante', description: 'Un coach présent pour vous pousser à chaque séance.' },
      { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>', title: 'Séances optimisées', description: 'Efficaces et structurées, chaque minute compte.' },
      { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>', title: 'Résultats durables', description: 'Vous êtes accompagné du début à la fin.' },
    ]}
  />

  <!-- COMMENT CA SE PASSE -->
  <ProcessTimeline
    label="Le processus"
    title="Un suivi structuré"
    steps={[
      { number: '1', title: 'Échange', description: 'Définition de vos objectifs et bilan initial.' },
      { number: '2', title: 'Programme', description: 'Mise en place d\'un plan personnalisé.' },
      { number: '3', title: 'Séances', description: 'Entraînements encadrés en salle.' },
      { number: '4', title: 'Suivi', description: 'Ajustements selon votre progression.' },
      { number: '5', title: 'Résultats', description: 'Objectifs atteints, progression visible.' },
    ]}
  />

  <!-- L'EQUIPE -->
  <ContentSection
    label="L'équipe"
    title="Nasr & son équipe"
    mediaSrc="https://images.unsplash.com/photo-1595078475328-1ab05d0a6a0e?w=800&q=80"
    mediaAlt="Nasr et son équipe"
    mediaPosition="right"
    variant="dark"
  >
    <p>16 ans d'expérience dans le sport et le fitness. Createur et gérant de Victory Fit.</p>
    <p>Le coaching est assuré par Nasr ainsi que par des coachs indépendants sélectionnés avec soin.</p>
    <p><strong>Tous partagent la même exigence : qualité, accompagnement et résultats.</strong></p>
  </ContentSection>

  <!-- EMS -->
  <ContentSection
    label="Option premium"
    title="Coaching + EMS"
    mediaSrc="https://images.unsplash.com/photo-1594737625785-a6cbdabd333c?w=800&q=80"
    mediaAlt="EMS"
    mediaPosition="left"
    ctas={[
      { label: 'Nous contacter', href: `${base}contact`, variant: 'primary' },
    ]}
  >
    <p>Possibilité d'intégrer des séances d'électrostimulation (EMS) dans votre programme.</p>
    <p><strong>Un travail musculaire intensif en un temps réduit.</strong></p>
    <p>Disponible uniquement en coaching privé, avec un accompagnement personnalisé.</p>
  </ContentSection>

  <!-- FINAL CTA -->
  <ContentSection
    title="Prêt à passer au niveau supérieur ?"
    fullWidth={true}
    variant="gradient"
    ctas={[
      { label: 'Nous contacter', href: `${base}contact`, variant: 'primary' },
      { label: 'Demander un bilan gratuit', href: `${base}contact`, variant: 'secondary' },
      { label: 'Je rejoins la famille Victory Fit', href: `${base}contact`, variant: 'secondary' },
    ]}
  >
    <p><strong>Le coaching personnalisé est le moyen le plus rapide d'atteindre vos objectifs.</strong></p>
  </ContentSection>

</BaseLayout>
