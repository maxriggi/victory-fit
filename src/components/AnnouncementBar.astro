---
const base = import.meta.env.BASE_URL;
---

<aside class="announce" id="announce-bar" aria-label="Annonce — ouverture prochaine">
  <a href={`${base}tarifs`} class="announce__link">
    <span class="announce__icon" aria-hidden="true">🔥</span>
    <span class="announce__text">
      <strong>Ouverture prochaine à Metz</strong>
      <span class="announce__sub"> — soyez les premiers informés</span>
    </span>
    <span class="announce__cta">S'inscrire&nbsp;→</span>
  </a>
  <button class="announce__close" id="announce-close" type="button" aria-label="Fermer l'annonce">&times;</button>
</aside>

<script is:inline>
  (function () {
    var bar = document.getElementById('announce-bar');
    if (!bar) return;
    if (localStorage.getItem('vf-announce-dismissed') === '1') {
      bar.remove();
      return;
    }
    var btn = document.getElementById('announce-close');
    if (btn) {
      btn.addEventListener('click', function () {
        localStorage.setItem('vf-announce-dismissed', '1');
        bar.remove();
      });
    }
  })();
</script>

<style>
  .announce {
    position: relative;
    z-index: 101;
    background: var(--gradient-horizontal);
    text-align: center;
  }

  .announce__link {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    width: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0.6rem 3rem;
    color: var(--white);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.3;
  }

  .announce__icon {
    font-size: 1rem;
    flex: 0 0 auto;
  }

  .announce__text strong {
    color: var(--white);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .announce__sub {
    color: var(--white);
    opacity: 0.85;
  }

  .announce__cta {
    flex: 0 0 auto;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.2s ease;
  }

  .announce__link:hover .announce__cta {
    opacity: 0.8;
  }

  .announce__close {
    position: absolute;
    right: 0.6rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: var(--white);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    padding: 0.1rem 0.5rem;
    opacity: 0.75;
    transition: opacity 0.2s ease;
  }

  .announce__close:hover {
    opacity: 1;
  }

  @media (max-width: 600px) {
    .announce__link {
      flex-wrap: wrap;
      padding: 0.5rem 2.4rem;
      font-size: 0.72rem;
      gap: 0.35rem 0.5rem;
    }
    .announce__sub {
      display: none;
    }
    .announce__cta {
      flex-basis: 100%;
    }
    .announce__close {
      top: 0.5rem;
      transform: none;
    }
  }
</style>
