---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Page introuvable — Victory Fit" description="Cette page n'existe pas ou a été déplacée.">

  <section class="error-page">
    <div class="error-page__inner">
      <div class="error-page__code">404</div>
      <h1 class="error-page__title">Page introuvable</h1>
      <p class="error-page__text">Cette page n'existe pas ou a été déplacée.</p>
      <p class="error-page__text"><strong>Pas de panique, la victoire est ailleurs.</strong></p>
      <div class="cta-group" style="margin-top: 2rem; justify-content: center;">
        <a href={base} class="btn btn--primary">Retour à l'accueil</a>
        <a href={`${base}cours`} class="btn btn--secondary">Voir les cours <span class="btn__arrow">&rarr;</span></a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .error-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
  }

  .error-page__inner {
    max-width: 560px;
  }

  .error-page__code {
    font-family: var(--font-heading);
    font-size: clamp(8rem, 20vw, 14rem);
    line-height: 1;
    letter-spacing: 0.05em;
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-deep) 50%, var(--burgundy) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1rem;
  }

  .error-page__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .error-page__text {
    color: var(--white-70);
    font-size: 1.1rem;
    line-height: 1.7;
  }

  .error-page__text + .error-page__text {
    margin-top: 0.5rem;
  }
</style>
