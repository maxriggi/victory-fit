---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import ContentSection from '../../components/ContentSection.astro';
import RelatedCourses from '../../components/RelatedCourses.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Sport Doux & Relaxation — Victory Fit" description="Cours de yoga, pilates et stretching chez Victory Fit à Metz : bien-être, récupération et équilibre du corps." breadcrumbs={[{ label: 'Accueil', href: base }, { label: 'Les Cours', href: base + 'cours' }, { label: 'Sport Doux & Relaxation' }]}>

  <HeroSection
    title="Sport Doux & Relaxation"
    highlightWord="Relaxation"
    subtitle="Yoga, pilates, stretching — des séances dédiées au bien-être, à la récupération et à l'équilibre du corps.<br><strong>Prendre soin de soi, c'est aussi du sport.</strong>"
    backgroundImage="https://images.unsplash.com/photo-1518310383802-640c2de311b2?w=1920&q=80"
    ctas={[
      { label: 'Voir le planning', href: `${base}planning`, variant: 'primary' },
      { label: 'Essai gratuit', href: `${base}contact`, variant: 'secondary' },
    ]}
  />

  <ContentSection
    label="Les activités"
    title="Trois disciplines, un objectif : le bien-être"
    mediaSrc="https://images.unsplash.com/photo-1518310383802-640c2de311b2?w=800&q=80"
    mediaAlt="Yoga et Pilates"
    mediaPosition="right"
  >
    <p><strong>Yoga</strong> — postures, respiration et méditation pour la souplesse, la force intérieure et la réduction du stress.</p>
    <p><strong>Pilates</strong> — renforcement profond du core, amélioration de la posture et de l'alignement corporel. Exercices précis et contrôlés.</p>
    <p><strong>Stretching</strong> — étirements guidés pour améliorer la mobilité, soulager les tensions et favoriser la récupération musculaire.</p>
  </ContentSection>

  <ContentSection
    label="Les bénéfices"
    title="Pourquoi le sport doux ?"
    fullWidth={true}
    variant="dark"
  >
    <ul>
      <li>Améliorer la mobilité et la souplesse</li>
      <li>Réduire le stress et l'anxiété</li>
      <li>Renforcer en douceur les muscles profonds</li>
      <li>Améliorer la posture et l'alignement</li>
      <li>Favoriser la récupération après les séances intenses</li>
      <li>Complément idéal à tous les autres cours Victory Fit</li>
    </ul>
    <p><strong>Accessible à tous les niveaux, tous les âges.</strong></p>
  </ContentSection>

  <RelatedCourses currentSlug="sport-doux" />

  <ContentSection
    title="Prêt à prendre soin de vous ?"
    fullWidth={true}
    variant="gradient"
    ctas={[
      { label: 'Voir le planning', href: `${base}planning`, variant: 'primary' },
      { label: 'Essai gratuit', href: `${base}contact`, variant: 'secondary' },
    ]}
  >
    <p><strong>La première victoire commence par une décision.</strong></p>
  </ContentSection>

</BaseLayout>
