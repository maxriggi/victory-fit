---
interface Props {
  title?: string;
  label?: string;
  courses: Array<{ image: string; title: string; description: string; href: string }>;
}

const { title, label, courses = [] } = Astro.props;
---

<section class="course-cards" data-aos="fade-up">
  <div class="course-cards__inner container">
    {label && <span class="course-cards__label" data-aos="fade-up">{label}</span>}
    {title && <h2 class="course-cards__title" data-aos="fade-up">{title}</h2>}
    <div class="course-cards__grid">
      {courses.map((course, i) => (
        <article
          class="course-card"
          data-aos="fade-up"
          data-aos-delay={String(i * 100)}
        >
          <div class="course-card__image-wrap">
            <img
              src={course.image}
              alt={course.title}
              loading="lazy"
              width="600"
              height="338"
            />
          </div>
          <div class="course-card__body">
            <h3 class="course-card__title">{course.title}</h3>
            <p class="course-card__desc">{course.description}</p>
            <a href={course.href} class="course-card__link">
              En savoir plus <span aria-hidden="true">&rarr;</span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .course-cards {
    padding: var(--section-padding);
  }

  .course-cards__inner {
    text-align: center;
  }

  .course-cards__label {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--orange);
    margin-bottom: 0.75rem;
  }

  .course-cards__title {
    margin-bottom: 2.5rem;
  }

  .course-cards__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    text-align: left;
  }

  /* ── Card ── */
  .course-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--white-10);
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .course-card:hover {
    transform: translateY(-4px);
    border-color: var(--orange);
  }

  /* ── Image ── */
  .course-card__image-wrap {
    overflow: hidden;
    border-radius: 12px 12px 0 0;
  }

  .course-card__image-wrap img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .course-card:hover .course-card__image-wrap img {
    transform: scale(1.03);
  }

  /* ── Body ── */
  .course-card__body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .course-card__title {
    font-family: var(--font-heading);
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--white);
    margin-bottom: 0.5rem;
  }

  .course-card__desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--white-70);
    margin-bottom: 1rem;
    flex: 1;
  }

  .course-card__link {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--orange);
    text-decoration: none;
    transition: color 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
  }

  .course-card__link:hover {
    color: var(--orange-deep);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .course-cards__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .course-cards__grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
