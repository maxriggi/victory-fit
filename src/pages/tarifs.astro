---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import ContentSection from '../components/ContentSection.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Tarifs — Victory Fit" description="Découvrez les tarifs Victory Fit : cours collectifs en illimité au cœur de Metz." breadcrumbs={[{ label: 'Accueil', href: base }, { label: 'Tarifs' }]}>

  <HeroSection
    title="Nos tarifs"
    highlightWord="tarifs"
    subtitle="Des cours collectifs en présentiel et en illimité.<br>Plus vous venez, plus vous progressez."
    backgroundImage="https://images.unsplash.com/photo-1593079831268-3381b0db4a77?w=1920&q=80"
    ctas={[
      { label: 'Essai gratuit', href: `${base}contact`, variant: 'primary' },
    ]}
  />

  <section class="sportigo-section" data-aos="fade-up">
    <div class="container">
      <h2 class="sportigo-title">Choisissez votre formule</h2>
      <div id="sportigo-buy-from-list-container"></div>
    </div>
  </section>

  <script is:inline src="https://standalone.api.sportigo.fr/component-standalone.js"></script>
  <script is:inline>
    initComponent("BuyFromList", "sportigo-buy-from-list-container", "2b0a9501-fb94-49ab-bca8-d660557b76c1", {
      "inline": false,
      "hideFilters": false,
      "initOfferPayment": {
        "cancelable": false
      }
    });
  </script>

  <ContentSection
    title="Prêt à nous rejoindre ?"
    fullWidth={true}
    variant="gradient"
    ctas={[
      { label: 'Nous contacter', href: `${base}contact`, variant: 'primary' },
      { label: 'Voir les cours', href: `${base}cours`, variant: 'secondary' },
    ]}
  >
    <p><strong>La première victoire commence par une décision.</strong></p>
  </ContentSection>

  <style>
    .sportigo-section {
      padding: var(--section-padding);
    }
    .sportigo-title {
      text-align: center;
      margin-bottom: 2rem;
    }
    #sportigo-buy-from-list-container {
      max-width: 1100px;
      margin: 0 auto;
    }
  </style>
</BaseLayout>
