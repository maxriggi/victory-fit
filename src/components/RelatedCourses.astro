---
interface Props {
  currentSlug: string;
}

const base = import.meta.env.BASE_URL;
const { currentSlug } = Astro.props;

const allCourses = [
  { slug: 'les-mills', label: 'Les Mills', description: 'Programmes fitness reconnus dans le monde entier, rythmés par la musique.', image: 'https://images.unsplash.com/photo-1534258936925-c58bed479fcb?w=600&q=80' },
  { slug: 'bungee-fitness', label: 'Bungee Fitness', description: 'Sauter, voler et se dépasser en protégeant ses articulations.', image: 'https://images.unsplash.com/photo-1518310383802-640c2de311b2?w=600&q=80' },
  { slug: 'boxe-training', label: 'Boxe Training', description: 'Défoulement total inspiré des sports de combat, zéro contact.', image: 'https://images.unsplash.com/photo-1549719386-74dfcbf7dbed?w=600&q=80' },
  { slug: 'cardio-training', label: 'Cardio Training', description: 'HIIT et entraînement cardio haute intensité.', image: 'https://images.unsplash.com/photo-1594737625785-a6cbdabd333c?w=600&q=80' },
  { slug: 'body-sculpt', label: 'Body Sculpt', description: 'Renforcement musculaire complet au poids du corps et avec charges légères.', image: 'https://images.unsplash.com/photo-1581009146145-b5ef050c2e1e?w=600&q=80' },
  { slug: 'ems', label: 'EMS', description: 'Électrostimulation musculaire pour un travail intense en 20 minutes.', image: 'https://images.unsplash.com/photo-1548690312-e3b507d8c110?w=600&q=80' },
  { slug: 'step-freestyle', label: 'Step Freestyle', description: 'Chorégraphies dynamiques sur step, cardio et coordination.', image: 'https://images.unsplash.com/photo-1599058917212-d750089bc07e?w=600&q=80' },
  { slug: 'sport-doux', label: 'Sport Doux', description: 'Yoga, Pilates, stretching — bien-être et souplesse.', image: 'https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=600&q=80' },
];

const related = allCourses.filter(c => c.slug !== currentSlug);
---

<section class="related-courses" data-aos="fade-up">
  <div class="related-courses__inner container">
    <h2>Découvrez nos autres cours</h2>
    <div class="related-courses__grid">
      {related.map((course, i) => (
        <a
          href={`${base}cours/${course.slug}`}
          class="related-card"
          aria-label={`En savoir plus sur ${course.label}`}
          data-aos="fade-up"
          data-aos-delay={String(i * 80)}
        >
          <div class="related-card__image">
            <img src={course.image} alt={course.label} loading="lazy" width="600" height="338" />
          </div>
          <div class="related-card__body">
            <h3 class="related-card__title">{course.label}</h3>
            <p class="related-card__desc">{course.description}</p>
            <span class="related-card__link">En savoir plus <span aria-hidden="true">&rarr;</span></span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .related-courses {
    padding: var(--section-padding);
    background: var(--bg-light);
    border-top: 1px solid var(--white-10);
  }

  .related-courses__inner {
    text-align: center;
  }

  .related-courses__inner h2 {
    margin-bottom: 2.5rem;
  }

  .related-courses__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    text-align: left;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--white-10);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .related-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
  }

  .related-card__image {
    overflow: hidden;
  }

  .related-card__image img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .related-card:hover .related-card__image img {
    transform: scale(1.03);
  }

  .related-card__body {
    padding: 1rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .related-card__title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--white);
    margin-bottom: 0.4rem;
  }

  .related-card__desc {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--white-70);
    margin-bottom: 0.75rem;
    flex: 1;
  }

  .related-card__link {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    transition: color 0.2s ease;
  }

  .related-card:hover .related-card__link {
    color: var(--accent-deep);
  }

  @media (max-width: 1024px) {
    .related-courses__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .related-courses__grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }
</style>
