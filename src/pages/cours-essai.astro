---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Réserver un cours d'essai gratuit — Victory Fit Metz"
  description="Réservez en ligne votre cours d'essai gratuit chez Victory Fit, la salle de sport du centre-ville de Metz. Choisissez votre créneau et venez tester nos cours collectifs."
  breadcrumbs={[{ label: 'Accueil', href: base }, { label: "Cours d'essai" }]}
>

  <HeroSection
    title="Cours d'essai gratuit"
    highlightWord="essai gratuit"
    subtitle="Choisissez votre créneau ci-dessous et venez vivre l'expérience Victory Fit.<br><strong>Premier cours offert, sans engagement.</strong>"
    backgroundImage="https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=1920&q=80"
  />

  <!-- SPORTIGO BOOKING WIDGET -->
  <section class="booking-section" data-aos="fade-up">
    <div class="container">
      <div class="booking-card">
        <div id="sportigo-appointment-container"></div>
      </div>
      <p class="booking-help">
        Un souci pour réserver ? <a href={`${base}contact`}>Contactez-nous</a> et on s'occupe de tout.
      </p>
    </div>
  </section>

  <script is:inline src="https://standalone.api.sportigo.fr/component-standalone.js"></script>
  <script is:inline>
    function vfInitSportigo() {
      if (typeof initComponent === 'undefined') {
        setTimeout(vfInitSportigo, 150);
        return;
      }
      initComponent("Appointment", "sportigo-appointment-container", "2b0a9501-fb94-49ab-bca8-d660557b76c1", {
        readonly: false,
        forceBookBtn: false,
        colored: true
      });
    }
    vfInitSportigo();
  </script>

</BaseLayout>

<style>
  .booking-section {
    padding: var(--section-padding);
  }

  .booking-card {
    background: var(--white);
    border-radius: 12px;
    padding: 2rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
    overflow: hidden;
  }

  .booking-help {
    text-align: center;
    margin-top: 1.5rem;
    color: var(--white-70);
    font-size: 0.95rem;
  }

  .booking-help a {
    color: var(--accent);
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .booking-card {
      padding: 1rem;
    }
  }
</style>
