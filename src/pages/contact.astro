---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import ContentSection from '../components/ContentSection.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Contact — Victory Fit" description="Contactez Victory Fit, votre salle de sport au centre-ville de Metz. Réservez votre cours d'essai gratuit." breadcrumbs={[{ label: 'Accueil', href: base }, { label: 'Contact' }]}>

  <HeroSection
    title="Contactez-nous"
    highlightWord="Contactez-nous"
    subtitle="Victory Fit est situé en plein centre-ville de Metz, facilement accessible.<br><strong>Centre Saint-Jacques, entrée rue Tête d'or.</strong>"
    backgroundImage="https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=1920&q=80"
    ctas={[
      { label: 'Essai gratuit', href: '#contact-form', variant: 'primary' },
    ]}
  />

  <!-- CONTACT INFO -->
  <section class="contact-section" id="contact-form" data-aos="fade-up">
    <div class="contact-grid container">
      <div class="contact-info">
        <h2>Venez nous voir</h2>
        <div class="contact-item">
          <h3>Adresse</h3>
          <p>Centre Saint-Jacques, entrée rue Tête d'or</p>
        </div>
        <div class="contact-item">
          <h3>Horaires</h3>
          <p>Plusieurs créneaux chaque jour<br>Matin, midi et soir</p>
        </div>
        <div class="contact-item">
          <h3>Réseaux sociaux</h3>
          <div class="contact-social">
            <a href="#" target="_blank" rel="noopener">Instagram</a>
            <a href="#" target="_blank" rel="noopener">Facebook</a>
            <a href="#" target="_blank" rel="noopener">TikTok</a>
          </div>
        </div>
      </div>

      <div class="contact-form-wrap">
        <h2>Essai gratuit</h2>
        <p style="margin-bottom: 1.5rem;">Remplissez le formulaire pour réserver votre premier cours d'essai gratuit.</p>
        <form class="contact-form" action="https://formspree.io/f/maxime@riggi.tech" method="POST">
          <input type="hidden" name="_subject" value="Nouveau contact Victory Fit">
          <input type="text" name="_gotcha" style="display:none">
          <div class="form-group">
            <label for="name">Nom complet</label>
            <input type="text" id="name" name="name" required placeholder="Votre nom">
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required placeholder="votre@email.com">
          </div>
          <div class="form-group">
            <label for="phone">Téléphone</label>
            <input type="tel" id="phone" name="phone" placeholder="06 00 00 00 00">
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="4" placeholder="Votre message ou objectif sportif..."></textarea>
          </div>
          <button type="submit" class="btn btn--primary" style="width: 100%; justify-content: center;">Envoyer</button>
          <p class="form-success" style="display:none; color: var(--accent); text-align: center; margin-top: 1rem;">Merci ! Votre message a bien été envoyé.</p>
        </form>
      </div>
    </div>
  </section>

  <ContentSection
    title="La première victoire commence par une décision."
    fullWidth={true}
    variant="gradient"
    ctas={[
      { label: 'Voir le planning', href: `${base}planning`, variant: 'primary' },
      { label: 'Voir les cours', href: `${base}cours`, variant: 'secondary' },
    ]}
  >
    <p></p>
  </ContentSection>

</BaseLayout>

<style>
  .contact-section {
    padding: var(--section-padding);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  .contact-info h2,
  .contact-form-wrap h2 {
    margin-bottom: 2rem;
  }

  .contact-item {
    margin-bottom: 2rem;
  }

  .contact-item h3 {
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .contact-social {
    display: flex;
    gap: 1.5rem;
  }

  .contact-social a {
    color: var(--white-70);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.3s ease;
  }

  .contact-social a:hover {
    color: var(--accent);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--white-70);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .form-group input,
  .form-group textarea {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--white-10);
    border-radius: 4px;
    padding: 0.8rem 1rem;
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: border-color 0.3s ease;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--accent);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--white-50);
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
